// Prisma schema for the LDE receipt tracking system.
// Dev uses SQLite (file at prisma/dev.db, gitignored); swap the datasource
// to postgresql when deploying (see SETUP.md).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum PaymentMethod {
  bank_transfer
  zelle
  wire
  bofa_card
  citi_card
  home_depot_card
}

enum Category {
  overhead
  property
}

enum ReceiptSource {
  app_upload
  app_camera
  slack
  email_auto
}

enum TransactionSource {
  bofa
  citi
  home_depot
  manual
}

// Team logins, admin-assigned (no self-service signup) — see
// web/scripts/create-user.ts. Replaces the earlier Google OAuth approach
// so the CEO can hand out credentials directly instead of managing a
// Google Cloud OAuth consent screen and a team-email allowlist.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  // Admins can create/update other team logins from /team; everyone else
  // just signs in and uses the app.
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// Canonical properties, mirrors receipt-recon/houses.py::HOUSES so the app
// and the CLI matcher never drift on naming.
model Property {
  id            String        @id @default(cuid())
  name          String        @unique
  createdAt     DateTime      @default(now())
  receipts      Receipt[]
  transactions  Transaction[]
  supplyOrders  SupplyOrder[]
}

model Receipt {
  id            String        @id @default(cuid())
  // Storage backend fields — exactly one of (fileId+fileUrl) or storagePath
  // is populated, depending on which StorageAdapter is active. See
  // web/lib/storage/.
  fileId        String?
  fileUrl       String?
  storagePath   String?
  uploadedBy    String
  category      Category
  propertyId    String?
  property      Property?     @relation(fields: [propertyId], references: [id])
  description   String
  // Nullable: the app's Add Receipt form always collects this, but Slack
  // messages often don't state a payment method explicitly — those land as
  // null rather than a guessed value, for human follow-up.
  paymentMethod PaymentMethod?
  source        ReceiptSource
  capturedAt    DateTime      @default(now())
  createdAt     DateTime      @default(now())
  // Populated once the Notion ledger sync succeeds; null means "not synced
  // yet" (e.g. NOTION_TOKEN isn't configured), not an error state.
  notionPageId  String?
  // Slack message identity, for de-duplicating on Slack's automatic retries
  // (it retries any event whose webhook ack takes too long or errors).
  slackChannel  String?
  slackTs       String?

  transactions TransactionReceipt[]

  @@index([capturedAt])
  @@index([propertyId])
  @@index([slackChannel, slackTs])
}

// Generalizes receipt-recon's Charge (bofa.py/citi.py) and HDRow
// (home_depot.py) to every payment method, including manually-logged
// bank/Zelle/wire entries that have no statement PDF to parse.
model Transaction {
  id            String            @id @default(cuid())
  source        TransactionSource
  issuer        String?
  last4         String?
  txnDate       DateTime
  postDate      DateTime?
  description   String
  amountCents   Int
  paymentMethod PaymentMethod
  category      Category?
  propertyId    String?
  property      Property?         @relation(fields: [propertyId], references: [id])
  needsReview   Boolean           @default(true)
  isSplit       Boolean           @default(false)
  sourceFile    String?
  notionPageId  String?
  createdAt     DateTime          @default(now())

  receipts TransactionReceipt[]

  @@index([txnDate])
  @@index([propertyId])
  @@index([needsReview])
}

// Join table: a transaction can be covered by multiple receipts (itemized
// splits) and, in principle, a receipt could cover more than one line item.
model TransactionReceipt {
  transactionId String
  receiptId     String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  receipt       Receipt     @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@id([transactionId, receiptId])
}

enum SupplyVendor {
  amazon
  instacart
  costco
  home_depot
  specialty
  pool_supply
  other
}

enum SupplyOrderStatus {
  pending
  ordered
  delivered
}

// Catalog of purchasable supply items, seeded from
// prisma/seed-supply-items.json (generated from the team's supply
// spreadsheet). `url` is the vendor product link teams click through to buy;
// kept editable here rather than hard-coded so links can be fixed without a
// deploy.
model SupplyItem {
  id               String        @id @default(cuid())
  name             String        @unique
  // Clean, team-facing label (e.g. "Sheet Set", "13 Gallon Trash Bags")
  // shown instead of the full scraped product title on the ordering page
  // and order sheet; falls back to `name` when not set.
  shortName        String?
  vendor           SupplyVendor
  url              String?
  imageUrl         String?
  alternativeNote  String?
  notes            String?
  // Shown in the "Commonly Purchased" tab on the ordering page instead of
  // buried in the full catalog.
  isCommon         Boolean       @default(false)
  // e.g. ["Twin XL","Queen","King","Cal King"] for sheets/duvets/pillowcases;
  // null for items where a size selection doesn't apply.
  sizeOptions      Json?
  active           Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  orderItems       SupplyOrderItem[]
}

// One order sheet per property per submission. No approval workflow — the
// office places every order on the back end, so this is just
// pending (submitted) -> ordered (placed with vendor) -> delivered.
model SupplyOrder {
  id                String            @id @default(cuid())
  // Human-facing sequential number (e.g. "SO-0007"), assigned in
  // app/api/supplies/orders/route.ts at creation time — not a DB
  // autoincrement since SQLite only allows that on the @id field, and this
  // needs to survive the later Postgres migration unchanged. createdAt is
  // still the date of record; this is an additional identifier, not a
  // replacement for it.
  orderNumber       Int               @unique
  propertyId        String
  property          Property          @relation(fields: [propertyId], references: [id])
  requestedByEmail  String
  requestedByName   String?
  status            SupplyOrderStatus @default(pending)
  notes             String?
  orderedByEmail    String?
  orderedAt         DateTime?
  orderConfirmation String?
  expectedDelivery  DateTime?
  deliveredAt       DateTime?
  deliveryNotes     String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  items SupplyOrderItem[]

  @@index([propertyId])
  @@index([status])
}

model SupplyOrderItem {
  id           String      @id @default(cuid())
  orderId      String
  order        SupplyOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  // Null when this is a pasted ad-hoc link instead of a catalog item.
  supplyItemId String?
  supplyItem   SupplyItem? @relation(fields: [supplyItemId], references: [id])
  adHocName    String?
  adHocUrl     String?
  quantity     Int         @default(1)
  size         String?
  notes        String?

  @@index([orderId])
}
