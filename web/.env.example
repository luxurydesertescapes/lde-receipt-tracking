# Copy to .env.local for local dev (never commit the real file).

# --- Database (Postgres — Neon recommended, see SETUP.md) ---
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Auth (NextAuth, admin-assigned email/password logins) ---
# No OAuth needed. Create/update team logins with:
#   npx tsx scripts/create-user.ts <email> <password> [name]
AUTH_SECRET="" # generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# --- Google Drive storage (optional in dev; falls back to local disk) ---
# Service account JSON from a Google Cloud project with the Drive API
# enabled, shared on the target Drive folder. Paste the whole JSON as one
# line, or set GOOGLE_DRIVE_SERVICE_ACCOUNT_FILE to a path instead.
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=""
GOOGLE_DRIVE_SERVICE_ACCOUNT_FILE=""
# The "Vendor Invoices & Receipts - Tax 2026" folder ID (or any target root).
GOOGLE_DRIVE_ROOT_FOLDER_ID=""

# --- Notion ledger sync (optional in dev; no-ops/logs when absent) ---
# Create an internal integration at https://www.notion.so/my-integrations,
# then share the target database with it.
NOTION_TOKEN=""
NOTION_DATABASE_ID=""

# --- Email auto-ingestion (optional; /email-accounts shows "not configured"
# until set) — Google OAuth client (separate from the Drive service
# account) with the Gmail API enabled, redirect URI
# <your-url>/api/email-accounts/callback. See SETUP.md.
GOOGLE_GMAIL_CLIENT_ID=""
GOOGLE_GMAIL_CLIENT_SECRET=""
# Authorizes the hourly Vercel Cron (web/vercel.json) to trigger a sync
# without an admin session. Any random string, e.g. `openssl rand -hex 32`.
CRON_SECRET=""

# --- Forgot-password admin notification (optional in dev; no-ops/logs when
# absent) — Gmail SMTP via an app password on a luxurydesertescapes.com
# Google account. Create one at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification on that account).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
# Optional — defaults to SMTP_USER if unset.
EMAIL_FROM=""

# --- Internal Python matching service (receipt-recon/service.py) ---
MATCHING_SERVICE_URL="http://127.0.0.1:8008"

# --- Slack ingestion (optional; the webhook 401s until configured) ---
# Create a Slack app at https://api.slack.com/apps with bot scopes
# channels:history, files:read, chat:write (+ users:read.email, channels:read
# optional — the latter lets the /email-accounts history-backfill search
# auto-discover channels instead of only SLACK_MONITORED_CHANNELS below), an
# Events API subscription to `message.channels` pointed at
# <your-url>/api/slack/events, and invite the bot to your receipt/supply/
# other/CEO channels.
SLACK_SIGNING_SECRET=""
SLACK_BOT_TOKEN=""
# Comma-separated channel IDs to ingest from (leave empty to watch every
# channel the bot is a member of — requires the channels:read scope above).
SLACK_MONITORED_CHANNELS=""
